<Application x:Class="SipClient.App"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:conv="clr-namespace:SipClient"
             StartupUri="Views/MainWindow.xaml">
    <Application.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="Resources/Styles.xaml"/>
            </ResourceDictionary.MergedDictionaries>

            <BooleanToVisibilityConverter x:Key="BoolToVis"/>
            <conv:InvertedBoolToVisibilityConverter x:Key="InvertedBoolToVis"/>
            <conv:StringToEmptyVisibilityConverter x:Key="StringToEmptyVis"/>
            <conv:DirectionToColorConverter x:Key="DirColorConverter"/>
            <conv:DirectionToIconConverter x:Key="DirIconConverter"/>
        </ResourceDictionary>
    </Application.Resources>
</Application>
