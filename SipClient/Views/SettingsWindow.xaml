<Window x:Class="SipClient.Views.SettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Настройки" Height="720" Width="460"
        MinHeight="500" MinWidth="400"
        WindowStartupLocation="CenterOwner"
        Background="#1A1A2E"
        ResizeMode="NoResize">

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0" Text="Настройки" FontSize="18" FontWeight="SemiBold"
                   Foreground="White" Margin="0,0,0,16"/>

        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto"
                      Padding="0,0,4,0">
            <StackPanel Margin="0,0,8,0">
                <TextBlock Text="SIP Аккаунт" Style="{StaticResource SectionHeader}"/>

                <Grid Margin="0,0,0,12">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="12"/>
                        <ColumnDefinition Width="100"/>
                    </Grid.ColumnDefinitions>
                    <StackPanel Grid.Column="0">
                        <TextBlock Text="Сервер" Style="{StaticResource FieldLabel}"/>
                        <TextBox Text="{Binding Server, UpdateSourceTrigger=PropertyChanged}"
                                 Style="{StaticResource ModernTextBox}"/>
                    </StackPanel>
                    <StackPanel Grid.Column="2">
                        <TextBlock Text="Порт" Style="{StaticResource FieldLabel}"/>
                        <TextBox Text="{Binding Port, UpdateSourceTrigger=PropertyChanged}"
                                 Style="{StaticResource ModernTextBox}"/>
                    </StackPanel>
                </Grid>

                <TextBlock Text="Локальный порт" Style="{StaticResource FieldLabel}"/>
                <TextBox Text="{Binding LocalPort, UpdateSourceTrigger=PropertyChanged}"
                         Style="{StaticResource ModernTextBox}" Margin="0,0,0,12"/>

                <TextBlock Text="Логин" Style="{StaticResource FieldLabel}"/>
                <TextBox Text="{Binding Username, UpdateSourceTrigger=PropertyChanged}"
                         Style="{StaticResource ModernTextBox}" Margin="0,0,0,12"/>

                <TextBlock Text="Пароль" Style="{StaticResource FieldLabel}"/>
                <Grid Margin="0,0,0,4">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <PasswordBox x:Name="PasswordBox"
                                 Padding="12,10" FontSize="14"
                                 Background="{StaticResource SurfaceCardBrush}"
                                 Foreground="{StaticResource TextPrimaryBrush}"
                                 BorderBrush="#585878" BorderThickness="1"/>
                    <ToggleButton x:Name="PasswordToggle" Grid.Column="1"
                                  Width="42" Margin="6,0,0,0"
                                  IsChecked="False"
                                  Cursor="Hand"
                                  ToolTip="Показать пароль"
                                  Click="PasswordToggle_Click">
                        <ToggleButton.Template>
                            <ControlTemplate TargetType="ToggleButton">
                                <Border x:Name="b" Background="{StaticResource SurfaceCardBrush}"
                                        BorderBrush="#585878" BorderThickness="1" CornerRadius="8"
                                        Padding="8,6">
                                    <Path x:Name="eyeIcon"
                                          Data="M12,4.5C7,4.5,2.73,7.61,1,12c1.73,4.39,6,7.5,11,7.5s9.27-3.11,11-7.5C22.27,7.61,17.99,4.5,12,4.5z M12,17c-2.76,0-5-2.24-5-5s2.24-5,5-5s5,2.24,5,5S14.76,17,12,17z M12,9c-1.66,0-3,1.34-3,3s1.34,3,3,3s3-1.34,3-3S13.66,9,12,9z"
                                          Width="16" Height="16" Stretch="Uniform"
                                          Fill="{StaticResource TextSecondaryBrush}"
                                          VerticalAlignment="Center" HorizontalAlignment="Center"/>
                                </Border>
                                <ControlTemplate.Triggers>
                                    <Trigger Property="IsChecked" Value="True">
                                        <Setter TargetName="eyeIcon" Property="Data"
                                                Value="M12,7c2.76,0,5,2.24,5,5c0,0.65-0.13,1.26-0.36,1.83l2.92,2.92c1.51-1.26,2.7-2.89,3.43-4.75c-1.73-4.39-6-7.5-11-7.5C8.55,4.17,7.13,4.73,5.92,5.61L7.59,7.28C9.06,7.1,10.47,7,12,7z M2,4.27l2.28,2.28l0.46,0.46C3.07,8.3,1.78,10.03,1,12c1.73,4.39,6,7.5,11,7.5c1.55,0,3.03-0.3,4.38-0.84l0.42,0.42L19.73,22L21,20.73L3.27,3L2,4.27z M7.53,9.8l1.55,1.55c-0.05,0.21-0.08,0.43-0.08,0.65c0,1.66,1.34,3,3,3c0.22,0,0.44-0.03,0.65-0.08l1.55,1.55c-0.67,0.33-1.41,0.53-2.2,0.53c-2.76,0-5-2.24-5-5C7.01,11.21,7.21,10.47,7.53,9.8z"/>
                                        <Setter TargetName="eyeIcon" Property="Fill" Value="White"/>
                                        <Setter TargetName="b" Property="Background" Value="{StaticResource PrimaryBrush}"/>
                                    </Trigger>
                                </ControlTemplate.Triggers>
                            </ControlTemplate>
                        </ToggleButton.Template>
                    </ToggleButton>
                </Grid>

                <TextBlock Text="Домен (SIP realm)" Style="{StaticResource FieldLabel}" Margin="0,12,0,6"/>
                <TextBox Text="{Binding Domain, UpdateSourceTrigger=PropertyChanged}"
                         Style="{StaticResource ModernTextBox}"/>

                <TextBlock Text="Auth логин" Style="{StaticResource FieldLabel}" Margin="0,12,0,6"/>
                <TextBox Text="{Binding AuthUsername, UpdateSourceTrigger=PropertyChanged}"
                         Style="{StaticResource ModernTextBox}"/>

                <TextBlock Text="Отображаемое имя" Style="{StaticResource FieldLabel}" Margin="0,12,0,6"/>
                <TextBox Text="{Binding DisplayName, UpdateSourceTrigger=PropertyChanged}"
                         Style="{StaticResource ModernTextBox}"/>

                <TextBlock Text="User-Agent" Style="{StaticResource FieldLabel}" Margin="0,12,0,6"/>
                <TextBox Text="{Binding UserAgent, UpdateSourceTrigger=PropertyChanged}"
                         Style="{StaticResource ModernTextBox}"/>

                <TextBlock Text="Аудиоустройства" Style="{StaticResource SectionHeader}"/>

                <TextBlock Text="Микрофон" Style="{StaticResource FieldLabel}"/>
                <ComboBox ItemsSource="{Binding CaptureDevices}"
                          SelectedItem="{Binding SelectedCaptureDevice}"
                          ItemContainerStyle="{StaticResource ModernComboBoxItem}"
                          Style="{StaticResource ModernComboBox}"
                          DisplayMemberPath="Name"/>

                <TextBlock Text="Динамик" Style="{StaticResource FieldLabel}" Margin="0,12,0,6"/>
                <ComboBox ItemsSource="{Binding PlaybackDevices}"
                          SelectedItem="{Binding SelectedPlaybackDevice}"
                          ItemContainerStyle="{StaticResource ModernComboBoxItem}"
                          Style="{StaticResource ModernComboBox}"
                          DisplayMemberPath="Name"/>

                <TextBlock Text="Кодеки" Style="{StaticResource SectionHeader}"/>
                <TextBlock Text="Первый в списке = предпочтительный. Отключите ненужные."
                           FontSize="11" Foreground="{StaticResource TextSecondaryBrush}" Margin="0,0,0,8"/>
                <ItemsControl ItemsSource="{Binding CodecOptions}">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Border Background="{StaticResource SurfaceCardBrush}" CornerRadius="8"
                                    Padding="12,8" Margin="0,0,0,4">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <CheckBox IsChecked="{Binding IsEnabled}" VerticalAlignment="Center"
                                              Margin="0,0,10,0"/>
                                    <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                        <TextBlock Text="{Binding Name}" FontSize="14" FontWeight="SemiBold"
                                                   Foreground="{StaticResource TextPrimaryBrush}"/>
                                        <TextBlock Text="{Binding Description}" FontSize="11"
                                                   Foreground="{StaticResource TextSecondaryBrush}"/>
                                    </StackPanel>
                                    <Button Grid.Column="2" Tag="{Binding}" Click="CodecMoveUp_Click"
                                            Style="{StaticResource GhostButton}" Margin="4,0"
                                            Width="28" Height="28" Padding="0">
                                        <Path Data="M7,14l5-5 5,5z" Width="12" Height="12"
                                              Stretch="Uniform" Fill="{StaticResource TextSecondaryBrush}"/>
                                    </Button>
                                    <Button Grid.Column="3" Tag="{Binding}" Click="CodecMoveDown_Click"
                                            Style="{StaticResource GhostButton}"
                                            Width="28" Height="28" Padding="0">
                                        <Path Data="M7,10l5,5 5-5z" Width="12" Height="12"
                                              Stretch="Uniform" Fill="{StaticResource TextSecondaryBrush}"/>
                                    </Button>
                                </Grid>
                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>

                <TextBlock Text="Громкость звонка" Style="{StaticResource SectionHeader}"/>
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="42"/>
                    </Grid.ColumnDefinitions>
                    <Slider Grid.Column="0" Style="{StaticResource ModernSlider}"
                            Value="{Binding RingVolume, Mode=TwoWay}" Minimum="0" Maximum="100"
                            Margin="0,0,8,0"/>
                    <TextBlock Grid.Column="1" Text="{Binding RingVolume, StringFormat={}{0:F0}%}"
                               FontSize="11" Foreground="{StaticResource TextSecondaryBrush}"
                               VerticalAlignment="Center" HorizontalAlignment="Center"/>
                </Grid>

                <TextBlock Text="Автоответ" Style="{StaticResource SectionHeader}"/>
                <CheckBox Content="Включить автоответ"
                          IsChecked="{Binding AutoAnswerEnabled}"
                          Foreground="{StaticResource TextPrimaryBrush}" Margin="0,0,0,8"/>

                <TextBlock Text="Задержка (сек)" Style="{StaticResource FieldLabel}"/>
                <TextBox Text="{Binding AutoAnswerDelay}"
                         Style="{StaticResource ModernTextBox}"/>

                <TextBlock Text="Регистрация" Style="{StaticResource SectionHeader}"/>
                <TextBlock Text="Период перерегистрации (сек)" Style="{StaticResource FieldLabel}"/>
                <TextBox Text="{Binding RegistrationExpiry}"
                         Style="{StaticResource ModernTextBox}"/>

                <TextBlock Text="RTP порты (медиа)" Style="{StaticResource SectionHeader}"/>
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="12"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <StackPanel Grid.Column="0">
                        <TextBlock Text="От" Style="{StaticResource FieldLabel}"/>
                        <TextBox Text="{Binding RtpPortMin}"
                                 Style="{StaticResource ModernTextBox}"/>
                    </StackPanel>
                    <StackPanel Grid.Column="2">
                        <TextBlock Text="До" Style="{StaticResource FieldLabel}"/>
                        <TextBox Text="{Binding RtpPortMax}"
                                 Style="{StaticResource ModernTextBox}"/>
                    </StackPanel>
                </Grid>

                <TextBlock Text="Отладка" Style="{StaticResource SectionHeader}"/>
                <CheckBox Content="Логирование SIP-пакетов (логи в папке logs/)"
                          IsChecked="{Binding SipLoggingEnabled}"
                          Foreground="{StaticResource TextPrimaryBrush}" Margin="0,0,0,8"/>
            </StackPanel>
        </ScrollViewer>

        <Button Grid.Row="2" Content="Сохранить" Command="{Binding SaveSettingsCommand}"
                Style="{StaticResource PrimaryButton}" Margin="0,16,0,0"
                HorizontalAlignment="Stretch"/>
    </Grid>
</Window>
