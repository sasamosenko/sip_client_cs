<Window x:Class="SipClient.Views.AboutWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="О приложении" Height="520" Width="380"
        WindowStartupLocation="CenterOwner"
        Background="#1A1A2E"
        ResizeMode="NoResize">

    <Grid Margin="24,20">
        <StackPanel HorizontalAlignment="Center">

            <!-- App icon -->
            <Path Data="M6.62,10.79C8.06,13.62 10.38,15.93 13.21,17.38L15.41,15.18C15.69,14.9 16.08,14.82 16.43,14.93C17.55,15.3 18.75,15.5 20,15.5C20.55,15.5 21,15.95 21,16.5V20C21,20.55 20.55,21 20,21C10.61,21 3,13.39 3,4C3,3.45 3.45,3 4,3H7.5C8.05,3 8.5,3.45 8.5,4C8.5,5.25 8.7,6.45 9.07,7.57C9.18,7.92 9.1,8.31 8.82,8.59L6.62,10.79Z"
                  Width="48" Height="48" Stretch="Uniform"
                  Fill="{StaticResource PrimaryBrush}" HorizontalAlignment="Center"
                  Margin="0,0,0,12"/>

            <TextBlock Text="SIP Client" FontSize="24" FontWeight="Bold"
                       Foreground="White" HorizontalAlignment="Center"/>
            <TextBlock Text="v1.0.0" FontSize="14"
                       Foreground="{StaticResource TextSecondaryBrush}" HorizontalAlignment="Center"
                       Margin="0,4,0,20"/>

            <Border Background="{StaticResource SurfaceCardBrush}" CornerRadius="10"
                    Padding="16,12" Margin="0,0,0,12">
                <StackPanel>
                    <TextBlock Text="Технологии" FontSize="12" FontWeight="SemiBold"
                               Foreground="{StaticResource TextSecondaryBrush}" Margin="0,0,0,6"/>
                    <TextBlock FontSize="13" Foreground="{StaticResource TextPrimaryBrush}"
                               TextWrapping="Wrap">
                        C# / .NET 8 / WPF&#x0a;
                        SIPSorcery 8.0.7 (SIP stack)&#x0a;
                        NAudio 2.2.1 (аудио)&#x0a;
                        CommunityToolkit.Mvvm
                    </TextBlock>
                </StackPanel>
            </Border>

            <Border Background="{StaticResource SurfaceCardBrush}" CornerRadius="10"
                    Padding="16,12" Margin="0,0,0,12">
                <StackPanel>
                    <TextBlock FontSize="13" Foreground="{StaticResource TextPrimaryBrush}"
                               TextWrapping="Wrap">
                        Разработка: <Run FontWeight="SemiBold">Станислав Самосенко</Run>
                    </TextBlock>
                    <TextBlock FontSize="13" Foreground="{StaticResource TextPrimaryBrush}"
                               TextWrapping="Wrap" Margin="0,4,0,0">
                        <Run FontWeight="SemiBold">ООО «Декодика»</Run>
                    </TextBlock>
                </StackPanel>
            </Border>

            <Border Background="{StaticResource SurfaceCardBrush}" CornerRadius="10"
                    Padding="16,12" Margin="0,0,0,12">
                <StackPanel>
                    <TextBlock FontSize="13" Foreground="{StaticResource TextPrimaryBrush}"
                               TextWrapping="Wrap">
                        Создано при поддержке AI-агента
                        <Run Foreground="{StaticResource PrimaryBrush}" FontWeight="SemiBold">MiMoCode</Run>
                        (Xiaomi MiMo Team)
                    </TextBlock>
                </StackPanel>
            </Border>

            <TextBlock FontSize="11" Foreground="{StaticResource TextSecondaryBrush}"
                       TextAlignment="Center" TextWrapping="Wrap"
                       Margin="0,8,0,0">
                Исходный код: github.com/sasamosenko/sip_client_cs
            </TextBlock>

        </StackPanel>
    </Grid>
</Window>
