<Window x:Class="SipClient.Views.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="clr-namespace:SipClient.ViewModels"
        Title="SIP Client" Height="600" Width="400"
        WindowStartupLocation="CenterScreen"
        Background="#1e1e1e">
    
    <Window.DataContext>
        <vm:MainViewModel />
    </Window.DataContext>
    
    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>
        
        <!-- Status Bar -->
        <Border Grid.Row="0" Background="#2d2d30" Padding="10" CornerRadius="5" Margin="0,0,0,10">
            <TextBlock Text="{Binding StatusText}" Foreground="{Binding StatusColor}" FontSize="14" FontWeight="Bold"/>
        </Border>
        
        <!-- Phone Number Input -->
        <Grid Grid.Row="1" Margin="0,0,0,10">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            
            <TextBox Grid.Column="0" Text="{Binding PhoneNumber, UpdateSourceTrigger=PropertyChanged}"
                     FontSize="20" Padding="10" Background="#3c3c3c" Foreground="White"
                     VerticalContentAlignment="Center"/>
            
            <Button Grid.Column="1" Content="📞" Command="{Binding CallCommand}"
                    FontSize="20" Padding="15" Margin="10,0,0,0"
                    Background="#4CAF50" Foreground="White" BorderThickness="0"/>
        </Grid>
        
        <!-- Call Controls (shown during call) -->
        <Border Grid.Row="2" Background="#2d2d30" Padding="10" CornerRadius="5"
                Visibility="{Binding IsInCall, Converter={StaticResource BoolToVisibility}}">
            <StackPanel>
                <TextBlock Text="In Call" FontSize="18" FontWeight="Bold" 
                           Foreground="White" HorizontalAlignment="Center" Margin="0,0,0,10"/>
                <TextBlock Text="{Binding CallDuration}" FontSize="32" 
                           Foreground="#4CAF50" HorizontalAlignment="Center" Margin="0,0,0,20"/>
                
                <!-- Volume Controls -->
                <Grid Margin="0,0,0,10">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="60"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="40"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Grid.Column="0" Text="Mic:" Foreground="White" VerticalAlignment="Center"/>
                    <Slider Grid.Column="1" Minimum="0" Maximum="100" 
                            Value="{Binding MicVolume, Mode=TwoWay}" VerticalAlignment="Center"/>
                    <TextBlock Grid.Column="2" Text="{Binding MicVolume}" Foreground="White" VerticalAlignment="Center"/>
                </Grid>
                
                <Grid Margin="0,0,0,20">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="60"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="40"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Grid.Column="0" Text="Spk:" Foreground="White" VerticalAlignment="Center"/>
                    <Slider Grid.Column="1" Minimum="0" Maximum="100" 
                            Value="{Binding SpeakerVolume, Mode=TwoWay}" VerticalAlignment="Center"/>
                    <TextBlock Grid.Column="2" Text="{Binding SpeakerVolume}" Foreground="White" VerticalAlignment="Center"/>
                </Grid>
                
                <!-- Hangup Button -->
                <Button Content="Hangup" Command="{Binding HangupCommand}"
                        Height="50" Background="#f44336" Foreground="White" 
                        FontSize="16" FontWeight="Bold" BorderThickness="0"/>
            </StackPanel>
        </Border>
        
        <!-- Call History -->
        <Border Grid.Row="2" Background="#2d2d30" Padding="10" CornerRadius="5"
                Visibility="{Binding IsInCall, Converter={StaticResource InvertedBoolToVisibility}}">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>
                
                <TextBlock Grid.Row="0" Text="Call History" FontSize="14" FontWeight="Bold"
                           Foreground="White" Margin="0,0,0,5"/>
                
                <ListView Grid.Row="1" ItemsSource="{Binding CallHistory}" 
                          Background="#3c3c3c" Foreground="White">
                    <ListView.View>
                        <GridView>
                            <GridViewColumn Header="Date" Width="120" 
                                DisplayMemberBinding="{Binding Timestamp, StringFormat='{}{0:dd.MM HH:mm}'}"/>
                            <GridViewColumn Header="Number" Width="100" 
                                DisplayMemberBinding="{Binding Number}"/>
                            <GridViewColumn Header="Dir" Width="40" 
                                DisplayMemberBinding="{Binding Direction}"/>
                            <GridViewColumn Header="Duration" Width="60" 
                                DisplayMemberBinding="{Binding DurationStr}"/>
                        </GridView>
                    </ListView.View>
                </ListView>
            </Grid>
        </Border>
        
        <!-- Settings Panel -->
        <Expander Grid.Row="3" Header="Settings" Foreground="White" Margin="0,10,0,0">
            <Grid Background="#2d2d30" Padding="10" Margin="0,5,0,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>
                
                <TextBlock Grid.Row="0" Grid.Column="0" Text="Server:" Foreground="White" Margin="0,0,10,5"/>
                <TextBox Grid.Row="0" Grid.Column="1" Text="{Binding Server}" Margin="0,0,0,5"/>
                
                <TextBlock Grid.Row="1" Grid.Column="0" Text="Port:" Foreground="White" Margin="0,0,10,5"/>
                <TextBox Grid.Row="1" Grid.Column="1" Text="{Binding Port}" Margin="0,0,0,5"/>
                
                <TextBlock Grid.Row="2" Grid.Column="0" Text="Username:" Foreground="White" Margin="0,0,10,5"/>
                <TextBox Grid.Row="2" Grid.Column="1" Text="{Binding Username}" Margin="0,0,0,5"/>
                
                <TextBlock Grid.Row="3" Grid.Column="0" Text="Password:" Foreground="White" Margin="0,0,10,5"/>
                <PasswordBox Grid.Row="3" Grid.Column="1" Margin="0,0,0,5"/>
                
                <CheckBox Grid.Row="4" Grid.ColumnSpan="2" Content="Auto-answer"
                          IsChecked="{Binding AutoAnswerEnabled}" Foreground="White" Margin="0,5,0,5"/>
                
                <TextBlock Grid.Row="5" Grid.Column="0" Text="Delay (s):" Foreground="White" Margin="0,0,10,5"/>
                <TextBox Grid.Row="5" Grid.Column="1" Text="{Binding AutoAnswerDelay}" Margin="0,0,0,5"/>
                
                <Button Grid.Row="6" Grid.ColumnSpan="2" Content="Save Settings"
                        Command="{Binding SaveSettingsCommand}" Margin="0,5,0,0"
                        Background="#2196F3" Foreground="White" BorderThickness="0" Padding="10"/>
            </Grid>
        </Expander>
        
        <!-- Connect Button -->
        <Button Grid.Row="4" Content="Connect" Command="{Binding ConnectCommand}"
                Height="40" Margin="0,10,0,0"
                Background="#2196F3" Foreground="White" FontSize="14" BorderThickness="0"/>
    </Grid>
</Window>
