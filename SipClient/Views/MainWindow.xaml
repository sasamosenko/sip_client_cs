<Window x:Class="SipClient.Views.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="clr-namespace:SipClient.ViewModels"
        Title="SIP Client" Height="800" Width="520"
        MinHeight="600" MinWidth="440"
        WindowStartupLocation="CenterScreen"
        Background="#1A1A2E"
        ResizeMode="CanResizeWithGrip">

    <Window.DataContext>
        <vm:MainViewModel />
    </Window.DataContext>

    <Window.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVis"/>
        <local:InvertedBoolToVisibilityConverter x:Key="InvertedBoolToVis"
            xmlns:local="clr-namespace:SipClient"/>
    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <Border Grid.Row="0" Background="#16213E" Padding="20,16">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <StackPanel Grid.Column="0">
                    <TextBlock Text="SIP Client" FontSize="20" FontWeight="Bold" Foreground="White"/>
                    <TextBlock Text="{Binding StatusText}" FontSize="12" Foreground="{Binding StatusBrush}"
                               Margin="0,4,0,0" TextWrapping="Wrap"/>
                </StackPanel>
                <Border Grid.Column="1" Width="12" Height="12" CornerRadius="6"
                        Background="{Binding StatusBrush}" VerticalAlignment="Top" Margin="0,4,0,0"/>
            </Grid>
        </Border>

        <!-- Dial Pad Area -->
        <Border Grid.Row="1" Background="#0F3460" Padding="20,16">
            <StackPanel>
                <!-- Number Display -->
                <Border Background="#1A1A2E" CornerRadius="12" Padding="16,14" Margin="0,0,0,14">
                    <Grid>
                        <TextBlock Text="{Binding PhoneNumber}" FontSize="28" FontWeight="Light"
                                   Foreground="White" HorizontalAlignment="Center"
                                   VerticalAlignment="Center"/>
                        <TextBlock Text="Введите номер" FontSize="14"
                                   Foreground="{StaticResource PlaceholderBrush}" HorizontalAlignment="Center"
                                   VerticalAlignment="Center"
                                   Visibility="{Binding PhoneNumber, Converter={StaticResource StringToEmptyVis}}"/>
                    </Grid>
                </Border>

                <!-- Quick Actions -->
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <Button Grid.Column="0" Content="Вызов" Command="{Binding CallCommand}"
                            Style="{StaticResource SuccessButton}" Margin="0,0,6,0"/>
                    <Button Grid.Column="1" Content="Ответить" Command="{Binding AnswerCommand}"
                            Style="{StaticResource PrimaryButton}" Margin="3,0,3,0"
                            Visibility="{Binding IsIncomingCall, Converter={StaticResource BoolToVis}}"/>
                    <Button Grid.Column="1" Content="Сброс" Command="{Binding HangupCommand}"
                            Style="{StaticResource DangerButton}" Margin="3,0,3,0"
                            Visibility="{Binding IsInCall, Converter={StaticResource BoolToVis}}"/>
                    <Button Grid.Column="2" Content="Настройки" Command="{Binding ToggleSettingsCommand}"
                            Style="{StaticResource GhostButton}" Margin="6,0,0,0"/>
                </Grid>
            </StackPanel>
        </Border>

        <!-- Main Content -->
        <Grid Grid.Row="2" Margin="16,12">
            <!-- Active Call Panel -->
            <Border Style="{StaticResource CardBorder}"
                    Visibility="{Binding IsInCall, Converter={StaticResource BoolToVis}}">
                <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                    <TextBlock Text="Активный звонок" FontSize="14" Foreground="{StaticResource TextSecondaryBrush}"
                               HorizontalAlignment="Center" Margin="0,0,0,8"/>
                    <TextBlock Text="{Binding ActiveCallNumber}" FontSize="22" FontWeight="SemiBold"
                               Foreground="White" HorizontalAlignment="Center" Margin="0,0,0,4"/>
                    <TextBlock Text="{Binding CallDuration}" FontSize="36" FontWeight="Light"
                               Foreground="{StaticResource PrimaryBrush}" HorizontalAlignment="Center"
                               Margin="0,0,0,24"/>

                    <!-- Mic Volume -->
                    <Grid Margin="0,0,0,8" Width="300">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="40"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="44"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="Mic" FontSize="12" VerticalAlignment="Center"
                                   HorizontalAlignment="Center" Foreground="{StaticResource TextSecondaryBrush}"/>
                        <Slider Grid.Column="1" Style="{StaticResource ModernSlider}"
                                Value="{Binding MicVolume, Mode=TwoWay}" Margin="4,0"/>
                        <TextBlock Grid.Column="2" Text="{Binding MicVolume, StringFormat={}{0}%}"
                                   FontSize="12" Foreground="{StaticResource TextSecondaryBrush}"
                                   VerticalAlignment="Center" HorizontalAlignment="Center"/>
                    </Grid>

                    <!-- Speaker Volume -->
                    <Grid Margin="0,0,0,20" Width="300">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="40"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="44"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="Spk" FontSize="12" VerticalAlignment="Center"
                                   HorizontalAlignment="Center" Foreground="{StaticResource TextSecondaryBrush}"/>
                        <Slider Grid.Column="1" Style="{StaticResource ModernSlider}"
                                Value="{Binding SpeakerVolume, Mode=TwoWay}" Margin="4,0"/>
                        <TextBlock Grid.Column="2" Text="{Binding SpeakerVolume, StringFormat={}{0}%}"
                                   FontSize="12" Foreground="{StaticResource TextSecondaryBrush}"
                                   VerticalAlignment="Center" HorizontalAlignment="Center"/>
                    </Grid>

                    <!-- Mute + Transfer + Hangup -->
                    <Grid Width="300">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="8"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="8"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <Button Grid.Column="0" Content="Mute" Command="{Binding ToggleMuteCommand}"
                                Style="{StaticResource GhostButton}"/>
                        <Button Grid.Column="2" Content="Transfer" Command="{Binding OpenTransferDialogCommand}"
                                Style="{StaticResource GhostButton}"/>
                        <Button Grid.Column="4" Content="Завершить" Command="{Binding HangupCommand}"
                                Style="{StaticResource DangerButton}"/>
                    </Grid>
                </StackPanel>
            </Border>

            <!-- Call History / Settings -->
            <Grid Visibility="{Binding IsInCall, Converter={StaticResource InvertedBoolToVis}}">
                <!-- Settings Panel (overlay) -->
                <Border Style="{StaticResource CardBorder}"
                        Visibility="{Binding ShowSettings, Converter={StaticResource BoolToVis}}"
                        Background="#1A1A2E" Panel.ZIndex="10">
                    <ScrollViewer VerticalScrollBarVisibility="Auto">
                        <StackPanel>
                            <Grid>
                                <TextBlock Text="Настройки" FontSize="18" FontWeight="SemiBold"
                                           Foreground="White" VerticalAlignment="Center"/>
                                <Button Content="Закрыть" HorizontalAlignment="Right"
                                        Command="{Binding ToggleSettingsCommand}"
                                        Style="{StaticResource GhostButton}"/>
                            </Grid>

                            <!-- SIP Account -->
                            <TextBlock Text="SIP Аккаунт" Style="{StaticResource SectionHeader}"/>
                            <TextBlock Text="Сервер" Style="{StaticResource FieldLabel}"/>
                            <TextBox Text="{Binding Server, UpdateSourceTrigger=PropertyChanged}"
                                     Style="{StaticResource ModernTextBox}"
                                     Tag="main.infinity.web-zaim.ru"/>
                            <TextBlock Text="Порт" Style="{StaticResource FieldLabel}" Margin="0,10,0,6"/>
                            <TextBox Text="{Binding Port, UpdateSourceTrigger=PropertyChanged}"
                                     Style="{StaticResource ModernTextBox}" Tag="5060"/>
                            <TextBlock Text="Домен (SIP realm)" Style="{StaticResource FieldLabel}" Margin="0,10,0,6"/>
                            <TextBox Text="{Binding Domain, UpdateSourceTrigger=PropertyChanged}"
                                     Style="{StaticResource ModernTextBox}"
                                     Tag="domain.server.com (если отличается от сервера)"/>
                            <TextBlock Text="Логин" Style="{StaticResource FieldLabel}" Margin="0,10,0,6"/>
                            <TextBox Text="{Binding Username, UpdateSourceTrigger=PropertyChanged}"
                                     Style="{StaticResource ModernTextBox}" Tag="SIP username"/>
                            <TextBlock Text="Auth логин" Style="{StaticResource FieldLabel}" Margin="0,10,0,6"/>
                            <TextBox Text="{Binding AuthUsername, UpdateSourceTrigger=PropertyChanged}"
                                     Style="{StaticResource ModernTextBox}"
                                     Tag="Если отличается от логина"/>
                            <TextBlock Text="Пароль" Style="{StaticResource FieldLabel}" Margin="0,10,0,6"/>
                            <PasswordBox x:Name="PasswordBox"
                                         Padding="12,12" FontSize="14" Height="42"
                                         Background="{StaticResource SurfaceCardBrush}"
                                         Foreground="{StaticResource TextPrimaryBrush}"
                                         BorderBrush="#505068" BorderThickness="1"
                                         VerticalContentAlignment="Center"/>
                            <TextBlock Text="Отображаемое имя" Style="{StaticResource FieldLabel}" Margin="0,10,0,6"/>
                            <TextBox Text="{Binding DisplayName, UpdateSourceTrigger=PropertyChanged}"
                                     Style="{StaticResource ModernTextBox}" Tag="From header"/>
                            <TextBlock Text="User-Agent" Style="{StaticResource FieldLabel}" Margin="0,10,0,6"/>
                            <TextBox Text="{Binding UserAgent, UpdateSourceTrigger=PropertyChanged}"
                                     Style="{StaticResource ModernTextBox}" Tag="SipClient/1.0"/>

                            <!-- Audio Devices -->
                            <TextBlock Text="Аудиоустройства" Style="{StaticResource SectionHeader}"/>
                            <TextBlock Text="Микрофон" Style="{StaticResource FieldLabel}"/>
                            <ComboBox ItemsSource="{Binding CaptureDevices}"
                                      SelectedItem="{Binding SelectedCaptureDevice}"
                                      DisplayMemberPath="Name"
                                      Padding="12,10" FontSize="14" Height="42"
                                      Background="{StaticResource SurfaceCardBrush}"
                                      Foreground="{StaticResource TextPrimaryBrush}"
                                      BorderBrush="#505068" BorderThickness="1"
                                      VerticalContentAlignment="Center"/>
                            <TextBlock Text="Динамик" Style="{StaticResource FieldLabel}" Margin="0,10,0,6"/>
                            <ComboBox ItemsSource="{Binding PlaybackDevices}"
                                      SelectedItem="{Binding SelectedPlaybackDevice}"
                                      DisplayMemberPath="Name"
                                      Padding="12,10" FontSize="14" Height="42"
                                      Background="{StaticResource SurfaceCardBrush}"
                                      Foreground="{StaticResource TextPrimaryBrush}"
                                      BorderBrush="#505068" BorderThickness="1"
                                      VerticalContentAlignment="Center"/>

                            <!-- Auto Answer -->
                            <TextBlock Text="Автоответ" Style="{StaticResource SectionHeader}"/>
                            <CheckBox Content="Включить автоответ"
                                      IsChecked="{Binding AutoAnswerEnabled}"
                                      Foreground="{StaticResource TextPrimaryBrush}" Margin="0,0,0,8"/>
                            <TextBlock Text="Задержка (сек)" Style="{StaticResource FieldLabel}"/>
                            <TextBox Text="{Binding AutoAnswerDelay}"
                                     Style="{StaticResource ModernTextBox}" Tag="3"/>

                            <!-- Registration -->
                            <TextBlock Text="Регистрация" Style="{StaticResource SectionHeader}"/>
                            <TextBlock Text="Период перерегистрации (сек)" Style="{StaticResource FieldLabel}"/>
                            <TextBox Text="{Binding RegistrationExpiry}"
                                     Style="{StaticResource ModernTextBox}" Tag="600"/>

                            <!-- RTP Ports -->
                            <TextBlock Text="RTP порты (медиа)" Style="{StaticResource SectionHeader}"/>
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="12"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <StackPanel Grid.Column="0">
                                    <TextBlock Text="От" Style="{StaticResource FieldLabel}"/>
                                    <TextBox Text="{Binding RtpPortMin}"
                                             Style="{StaticResource ModernTextBox}" Tag="10000"/>
                                </StackPanel>
                                <StackPanel Grid.Column="2">
                                    <TextBlock Text="До" Style="{StaticResource FieldLabel}"/>
                                    <TextBox Text="{Binding RtpPortMax}"
                                             Style="{StaticResource ModernTextBox}" Tag="20000"/>
                                </StackPanel>
                            </Grid>

                            <Button Content="Сохранить настройки" Command="{Binding SaveSettingsCommand}"
                                    Style="{StaticResource PrimaryButton}" Margin="0,20,0,8"
                                    HorizontalAlignment="Stretch"/>
                        </StackPanel>
                    </ScrollViewer>
                </Border>

                <!-- Call History -->
                <Border Style="{StaticResource CardBorder}"
                        Visibility="{Binding ShowSettings, Converter={StaticResource InvertedBoolToVis}}">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>

                        <TextBlock Grid.Row="0" Text="История звонков" FontSize="18" FontWeight="SemiBold"
                                   Foreground="White" Margin="0,0,0,12"/>

                        <ListBox Grid.Row="1" ItemsSource="{Binding CallHistory}"
                                 Style="{StaticResource ModernListBox}"
                                 ItemContainerStyle="{StaticResource ModernListBoxItem}">
                            <ListBox.ItemTemplate>
                                <DataTemplate>
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="48"/>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <Grid.RowDefinitions>
                                            <RowDefinition/>
                                            <RowDefinition/>
                                        </Grid.RowDefinitions>

                                        <Border Grid.Column="0" Grid.RowSpan="2" Width="40" Height="40"
                                                CornerRadius="20" HorizontalAlignment="Center"
                                                VerticalAlignment="Center" Margin="0,0,10,0">
                                            <Border.Background>
                                                <SolidColorBrush Color="{Binding DirectionColor}"/>
                                            </Border.Background>
                                            <TextBlock Text="{Binding DirectionIcon}" FontSize="12" FontWeight="Bold"
                                                       Foreground="White" HorizontalAlignment="Center"
                                                       VerticalAlignment="Center"/>
                                        </Border>

                                        <TextBlock Grid.Column="1" Grid.Row="0"
                                                   Text="{Binding Number}" FontSize="14" FontWeight="SemiBold"
                                                   Foreground="{StaticResource TextPrimaryBrush}"/>
                                        <TextBlock Grid.Column="1" Grid.Row="1"
                                                   Text="{Binding TimeDisplay}" FontSize="12"
                                                   Foreground="{StaticResource TextSecondaryBrush}"/>

                                        <StackPanel Grid.Column="2" Grid.RowSpan="2"
                                                    VerticalAlignment="Center" HorizontalAlignment="Right">
                                            <TextBlock Text="{Binding DurationStr}" FontSize="13"
                                                       Foreground="{StaticResource TextSecondaryBrush}"
                                                       HorizontalAlignment="Right"/>
                                            <TextBlock Text="{Binding StatusDisplay}" FontSize="11"
                                                       Foreground="{Binding StatusBrush}"
                                                       HorizontalAlignment="Right"/>
                                        </StackPanel>
                                    </Grid>
                                </DataTemplate>
                            </ListBox.ItemTemplate>
                        </ListBox>

                        <TextBlock Grid.Row="1" Text="Нет звонков"
                                   FontSize="14" Foreground="{StaticResource TextSecondaryBrush}"
                                   HorizontalAlignment="Center" VerticalAlignment="Center"
                                   Visibility="{Binding IsHistoryEmpty, Converter={StaticResource BoolToVis}}"/>
                    </Grid>
                </Border>
            </Grid>
        </Grid>

        <!-- Transfer Dialog Overlay -->
        <Border Grid.Row="0" Grid.RowSpan="4" Background="#CC000000" Panel.ZIndex="100"
                Visibility="{Binding ShowTransferDialog, Converter={StaticResource BoolToVis}}">
            <Border Style="{StaticResource CardBorder}" VerticalAlignment="Center"
                    HorizontalAlignment="Center" MinWidth="340" Margin="20">
                <StackPanel>
                    <TextBlock Text="Blind Transfer" FontSize="18" FontWeight="SemiBold"
                               Foreground="White" HorizontalAlignment="Center" Margin="0,0,0,16"/>
                    <TextBlock Text="Номер абонента" Style="{StaticResource FieldLabel}"/>
                    <TextBox Text="{Binding TransferNumber, UpdateSourceTrigger=PropertyChanged}"
                             Style="{StaticResource ModernTextBox}"/>
                    <Grid Margin="0,16,0,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="12"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <Button Grid.Column="0" Content="Отмена"
                                Command="{Binding CancelTransferCommand}"
                                Style="{StaticResource GhostButton}"/>
                        <Button Grid.Column="2" Content="Перевести"
                                Command="{Binding ExecuteTransferCommand}"
                                Style="{StaticResource PrimaryButton}"/>
                    </Grid>
                </StackPanel>
            </Border>
        </Border>

        <!-- Connect Button (shown when offline) -->
        <Border Grid.Row="3" Padding="16,12" Background="#16213E"
                Visibility="{Binding IsRegistered, Converter={StaticResource InvertedBoolToVis}}">
            <Button Content="Подключиться" Command="{Binding ConnectCommand}"
                    Style="{StaticResource PrimaryButton}"
                    HorizontalAlignment="Stretch"/>
        </Border>
    </Grid>
</Window>
