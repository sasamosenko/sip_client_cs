<Window x:Class="SipClient.Views.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="clr-namespace:SipClient.ViewModels"
        Title="SIP Client" Height="750" Width="420"
        WindowStartupLocation="CenterScreen"
        Background="#1A1A2E"
        ResizeMode="CanMinimize">
    
    <Window.DataContext>
        <vm:MainViewModel />
    </Window.DataContext>
    
    <Window.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVis"/>
        <local:InvertedBoolToVisibilityConverter x:Key="InvertedBoolToVis"
            xmlns:local="clr-namespace:SipClient"/>
    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <Border Grid.Row="0" Background="#16213E" Padding="20,18">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <StackPanel Grid.Column="0">
                    <TextBlock Text="SIP Client" FontSize="22" FontWeight="Bold" Foreground="White"/>
                    <TextBlock Text="{Binding StatusText}" FontSize="12" Foreground="{Binding StatusBrush}"
                               Margin="0,4,0,0"/>
                </StackPanel>
                <Border Grid.Column="1" Width="14" Height="14" CornerRadius="7"
                        Background="{Binding StatusBrush}" VerticalAlignment="Center"/>
            </Grid>
        </Border>

        <!-- Dial Pad Area -->
        <Border Grid.Row="1" Background="#0F3460" Padding="20,16">
            <StackPanel>
                <!-- Number Display -->
                <Border Background="#1A1A2E" CornerRadius="12" Padding="16,12" Margin="0,0,0,16">
                    <Grid>
                        <TextBlock Text="{Binding PhoneNumber}" FontSize="32" FontWeight="Light"
                                   Foreground="White" HorizontalAlignment="Center"
                                   VerticalAlignment="Center"/>
                        <TextBlock Text="Введите номер" FontSize="14"
                                   Foreground="#555570" HorizontalAlignment="Center"
                                   VerticalAlignment="Center"
                                   Visibility="{Binding PhoneNumber, Converter={StaticResource StringToEmptyVis}}"/>
                    </Grid>
                </Border>

                <!-- Quick Actions -->
                <Grid Margin="0,0,0,12">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <Button Grid.Column="0" Content="📞 Позвонить" Command="{Binding CallCommand}"
                            Style="{StaticResource SuccessButton}" Margin="0,0,6,0" Height="42"/>
                    <Button Grid.Column="1" Content="📞 Ответить" Command="{Binding AnswerCommand}"
                            Style="{StaticResource PrimaryButton}" Margin="3,0,3,0" Height="42"
                            Visibility="{Binding IsIncomingCall, Converter={StaticResource BoolToVis}}"/>
                    <Button Grid.Column="1" Content="✕ Сбросить" Command="{Binding HangupCommand}"
                            Style="{StaticResource DangerButton}" Margin="3,0,3,0" Height="42"
                            Visibility="{Binding IsInCall, Converter={StaticResource BoolToVis}}"/>
                    <Button Grid.Column="2" Content="⚙ Настройки" Command="{Binding ToggleSettingsCommand}"
                            Style="{StaticResource GhostButton}" Margin="6,0,0,0" Height="42"/>
                </Grid>
            </StackPanel>
        </Border>

        <!-- Main Content -->
        <Grid Grid.Row="2" Margin="16,12">
            <Grid.RowDefinitions>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- Active Call Panel -->
            <Border Grid.Row="0" Style="{StaticResource CardBorder}"
                    Visibility="{Binding IsInCall, Converter={StaticResource BoolToVis}}">
                <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                    <TextBlock Text="Активный звонок" FontSize="16" Foreground="{StaticResource TextSecondaryBrush}"
                               HorizontalAlignment="Center" Margin="0,0,0,8"/>
                    <TextBlock Text="{Binding ActiveCallNumber}" FontSize="24" FontWeight="SemiBold"
                               Foreground="White" HorizontalAlignment="Center" Margin="0,0,0,4"/>
                    <TextBlock Text="{Binding CallDuration}" FontSize="40" FontWeight="Light"
                               Foreground="{StaticResource PrimaryBrush}" HorizontalAlignment="Center"
                               Margin="0,0,0,24"/>

                    <!-- Mic Volume -->
                    <Grid Margin="0,0,0,12" Width="280">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="36"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="36"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="🎤" FontSize="16" VerticalAlignment="Center"
                                   HorizontalAlignment="Center"/>
                        <Slider Grid.Column="1" Style="{StaticResource ModernSlider}"
                                Value="{Binding MicVolume, Mode=TwoWay}" Margin="8,0"/>
                        <TextBlock Grid.Column="2" Text="{Binding MicVolume, StringFormat={}{0}%}"
                                   FontSize="12" Foreground="{StaticResource TextSecondaryBrush}"
                                   VerticalAlignment="Center" HorizontalAlignment="Center"/>
                    </Grid>

                    <!-- Speaker Volume -->
                    <Grid Margin="0,0,0,24" Width="280">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="36"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="36"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="🔊" FontSize="16" VerticalAlignment="Center"
                                   HorizontalAlignment="Center"/>
                        <Slider Grid.Column="1" Style="{StaticResource ModernSlider}"
                                Value="{Binding SpeakerVolume, Mode=TwoWay}" Margin="8,0"/>
                        <TextBlock Grid.Column="2" Text="{Binding SpeakerVolume, StringFormat={}{0}%}"
                                   FontSize="12" Foreground="{StaticResource TextSecondaryBrush}"
                                   VerticalAlignment="Center" HorizontalAlignment="Center"/>
                    </Grid>

                    <!-- Mute + Hangup -->
                    <Grid Width="280">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="12"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <Button Grid.Column="0" Content="🔇 Mute" Command="{Binding ToggleMuteCommand}"
                                Style="{StaticResource GhostButton}" Height="44"/>
                        <Button Grid.Column="2" Content="挂断" Command="{Binding HangupCommand}"
                                Style="{StaticResource DangerButton}" Height="44"/>
                    </Grid>
                </StackPanel>
            </Border>

            <!-- Call History / Settings -->
            <Grid Grid.Row="0" Visibility="{Binding IsInCall, Converter={StaticResource InvertedBoolToVis}}">
                <!-- Settings Panel (overlay) -->
                <Border Grid.Row="0" Style="{StaticResource CardBorder}"
                        Visibility="{Binding ShowSettings, Converter={StaticResource BoolToVis}}"
                        Background="#1A1A2E" Panel.ZIndex="10">
                    <ScrollViewer VerticalScrollBarVisibility="Auto">
                        <StackPanel>
                            <Grid>
                                <TextBlock Text="Настройки" FontSize="18" FontWeight="SemiBold"
                                           Foreground="White" VerticalAlignment="Center"/>
                                <Button Content="✕" HorizontalAlignment="Right"
                                        Command="{Binding ToggleSettingsCommand}"
                                        Style="{StaticResource GhostButton}" FontSize="16"/>
                            </Grid>

                            <TextBlock Text="SIP Аккаунт" FontSize="12" FontWeight="SemiBold"
                                       Foreground="{StaticResource TextSecondaryBrush}" Margin="0,16,0,8"/>
                            <TextBox Text="{Binding Server, UpdateSourceTrigger=PropertyChanged}"
                                     Style="{StaticResource ModernTextBox}"
                                     Tag="Сервер (напр. main.infinity.web-zaim.ru)"/>
                            <TextBox Text="{Binding Port, UpdateSourceTrigger=PropertyChanged}"
                                     Style="{StaticResource ModernTextBox}" Margin="0,8,0,0"
                                     Tag="Порт"/>
                            <TextBox Text="{Binding Username, UpdateSourceTrigger=PropertyChanged}"
                                     Style="{StaticResource ModernTextBox}" Margin="0,8,0,0"
                                     Tag="Логин"/>
                            <PasswordBox x:Name="PasswordBox" Margin="0,8,0,0"
                                         Padding="12,10" FontSize="14"
                                         Background="{StaticResource SurfaceCardBrush}"
                                         Foreground="{StaticResource TextPrimaryBrush}"
                                         BorderBrush="Transparent" BorderThickness="2"
                                         CornerRadius="8"/>

                            <TextBlock Text="Автоответ" FontSize="12" FontWeight="SemiBold"
                                       Foreground="{StaticResource TextSecondaryBrush}" Margin="0,20,0,8"/>
                            <CheckBox Content="Включить автоответ"
                                      IsChecked="{Binding AutoAnswerEnabled}"
                                      Foreground="{StaticResource TextPrimaryBrush}"/>
                            <Grid Margin="0,8,0,0">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="60"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0" Text="Задержка (сек):"
                                           Foreground="{StaticResource TextSecondaryBrush}"
                                           VerticalAlignment="Center"/>
                                <TextBox Grid.Column="1" Text="{Binding AutoAnswerDelay}"
                                         Style="{StaticResource ModernTextBox}"/>
                            </Grid>

                            <Button Content="Сохранить" Command="{Binding SaveSettingsCommand}"
                                    Style="{StaticResource PrimaryButton}" Margin="0,20,0,0"
                                    HorizontalAlignment="Stretch"/>
                        </StackPanel>
                    </ScrollViewer>
                </Border>

                <!-- Call History -->
                <Border Grid.Row="0" Style="{StaticResource CardBorder}"
                        Visibility="{Binding ShowSettings, Converter={StaticResource InvertedBoolToVis}}">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <TextBlock Grid.Row="0" Text="История звонков" FontSize="18" FontWeight="SemiBold"
                                   Foreground="White" Margin="0,0,0,12"/>

                        <ListBox Grid.Row="1" ItemsSource="{Binding CallHistory}"
                                 Style="{StaticResource ModernListBox}"
                                 ItemContainerStyle="{StaticResource ModernListBoxItem}">
                            <ListBox.ItemTemplate>
                                <DataTemplate>
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="48"/>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <Grid.RowDefinitions>
                                            <RowDefinition/>
                                            <RowDefinition/>
                                        </Grid.RowDefinitions>

                                        <!-- Direction Icon -->
                                        <Border Grid.Column="0" Grid.RowSpan="2" Width="40" Height="40"
                                                CornerRadius="20" HorizontalAlignment="Center"
                                                VerticalAlignment="Center" Margin="0,0,10,0">
                                            <Border.Background>
                                                <SolidColorBrush Color="{Binding DirectionColor}"/>
                                            </Border.Background>
                                            <TextBlock Text="{Binding DirectionIcon}" FontSize="16"
                                                       Foreground="White" HorizontalAlignment="Center"
                                                       VerticalAlignment="Center"/>
                                        </Border>

                                        <!-- Number -->
                                        <TextBlock Grid.Column="1" Grid.Row="0"
                                                   Text="{Binding Number}" FontSize="14" FontWeight="SemiBold"
                                                   Foreground="{StaticResource TextPrimaryBrush}"/>

                                        <!-- Time -->
                                        <TextBlock Grid.Column="1" Grid.Row="1"
                                                   Text="{Binding TimeDisplay}" FontSize="12"
                                                   Foreground="{StaticResource TextSecondaryBrush}"/>

                                        <!-- Duration -->
                                        <StackPanel Grid.Column="2" Grid.RowSpan="2"
                                                    VerticalAlignment="Center" HorizontalAlignment="Right">
                                            <TextBlock Text="{Binding DurationStr}" FontSize="13"
                                                       Foreground="{StaticResource TextSecondaryBrush}"
                                                       HorizontalAlignment="Right"/>
                                            <TextBlock Text="{Binding StatusDisplay}" FontSize="11"
                                                       Foreground="{Binding StatusBrush}"
                                                       HorizontalAlignment="Right"/>
                                        </StackPanel>
                                    </Grid>
                                </DataTemplate>
                            </ListBox.ItemTemplate>
                        </ListBox>

                        <TextBlock Grid.Row="1" Text="Нет звонков"
                                   FontSize="14" Foreground="{StaticResource TextSecondaryBrush}"
                                   HorizontalAlignment="Center" VerticalAlignment="Center"
                                   Visibility="{Binding IsHistoryEmpty, Converter={StaticResource BoolToVis}}"/>
                    </Grid>
                </Border>
            </Grid>
        </Grid>

        <!-- Connect Button (shown when offline) -->
        <Border Grid.Row="3" Padding="16,12" Background="#16213E"
                Visibility="{Binding IsRegistered, Converter={StaticResource InvertedBoolToVis}}">
            <Button Content="Подключиться" Command="{Binding ConnectCommand}"
                    Style="{StaticResource PrimaryButton}" Height="44"
                    HorizontalAlignment="Stretch"/>
        </Border>
    </Grid>
</Window>
